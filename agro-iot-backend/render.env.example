# Exemple de variables Render pour le backend Laravel.
# Ne jamais mettre les vraies valeurs dans GitHub.

APP_NAME=agro-iot
APP_ENV=production
APP_KEY=base64:GENERER_AVEC_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://votre-backend.onrender.com
ASSET_URL=https://votre-backend.onrender.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Render ne fournit pas MySQL manage comme Railway.
# Garder MySQL avec une base externe : Aiven, Clever Cloud, PlanetScale-compatible, serveur MySQL de votre hebergeur, etc.
DB_CONNECTION=mysql
DB_HOST=votre-host-mysql
DB_PORT=3306
DB_DATABASE=agro_lot
DB_USERNAME=votre-user
DB_PASSWORD=votre-password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Ajouter ici l'URL Vercel du frontend apres son deploiement.
# Plusieurs URLs peuvent etre separees par des virgules.
FRONTEND_URLS=https://votre-frontend.vercel.app,http://localhost:5174
