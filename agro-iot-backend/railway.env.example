# Exemple de variables Railway pour le backend Laravel.
# Ne pas mettre les vraies valeurs dans GitHub.

APP_NAME=agro-iot
APP_ENV=production
APP_KEY=base64:GENERER_AVEC_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://votre-backend.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# Mettre ici l'URL Vercel du frontend apres son deploiement.
# Plusieurs URLs peuvent etre separees par des virgules.
FRONTEND_URLS=https://votre-frontend.vercel.app,http://localhost:5174


