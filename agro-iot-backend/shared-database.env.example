# Configuration commune pour utiliser la meme base Aiven MySQL.
# Copier ces valeurs dans agro-iot-backend/.env chez chaque developpeur.
# Ne jamais mettre le vrai DB_PASSWORD dans GitHub.

DB_CONNECTION=mysql
DB_HOST=mysql-b28b9ca-ulc-bdb3.f.aivencloud.com
DB_PORT=14547
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=REMPLACER_PAR_LE_MOT_DE_PASSE_AIVEN

# Aiven indique SSL requis. Si la connexion echoue avec une erreur SSL,
# il faudra ajouter le certificat CA Aiven et renseigner MYSQL_ATTR_SSL_CA.
# MYSQL_ATTR_SSL_CA=/chemin/vers/ca.pem

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
